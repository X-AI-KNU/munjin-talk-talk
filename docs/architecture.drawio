<mxfile host="app.diagrams.net" modified="2026-06-08T00:00:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="munjin-architecture" name="문진톡톡 MVP Architecture">
    <mxGraphModel dx="1600" dy="1040" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1040" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="문진톡톡 MVP Architecture&#xa;고령 환자 음성 문진 → LangGraph/LangChain 기반 구조화 → 의료진 원페이퍼 → 환자 안내문" style="text;html=1;strokeColor=none;fillColor=none;fontSize=28;fontStyle=1;fontColor=#0f2347;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="900" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="laneClient" value="1. 사용자 화면" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=18;fontStyle=1;fontColor=#0f2347;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="40" y="130" width="300" height="790" as="geometry"/>
        </mxCell>
        <mxCell id="staff" value="직원 접수&#xa;/staff&#xa;세션 생성, 초진/재진, 대기열" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#93c5fd;fontSize=14;fontStyle=1;fontColor=#0f2347;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="205" width="240" height="94" as="geometry"/>
        </mxCell>
        <mxCell id="patient" value="환자 태블릿&#xa;/patient/:sessionId&#xa;서비스 이용 동의, 실시간 음성 문진, 직접 수정" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=14;fontStyle=1;fontColor=#0f2347;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="325" width="240" height="118" as="geometry"/>
        </mxCell>
        <mxCell id="doctor" value="의료진 화면&#xa;/doctor/queue, /doctor/:id&#xa;원페이퍼, 새로고침, AI 재검토, 답변 작성" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontSize=14;fontStyle=1;fontColor=#0f2347;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="470" width="240" height="118" as="geometry"/>
        </mxCell>
        <mxCell id="guide" value="환자 안내문&#xa;/guide/:sessionId&#xa;안내문 확인, TTS, 출력" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#22c55e;fontSize=14;fontStyle=1;fontColor=#0f2347;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="615" width="240" height="104" as="geometry"/>
        </mxCell>
        <mxCell id="laneHosting" value="2. 프론트 호스팅" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=18;fontStyle=1;fontColor=#0f2347;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="380" y="130" width="260" height="790" as="geometry"/>
        </mxCell>
        <mxCell id="amplify" value="AWS Amplify&#xa;React + Vite SPA&#xa;HTTPS 배포" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=14;fontStyle=1;fontColor=#0f2347;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="410" y="235" width="200" height="112" as="geometry"/>
        </mxCell>
        <mxCell id="browserStt" value="브라우저 STT&#xa;WebSocket streaming&#xa;음성 파일 업로드 없음&#xa;확정 텍스트만 API 전송" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#93c5fd;fontSize=14;fontStyle=1;fontColor=#0f2347;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="410" y="385" width="200" height="126" as="geometry"/>
        </mxCell>
        <mxCell id="laneApi" value="3. 서버리스 API / 파이프라인" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=18;fontStyle=1;fontColor=#0f2347;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="680" y="130" width="420" height="790" as="geometry"/>
        </mxCell>
        <mxCell id="api" value="API Gateway HTTP API&#xa;/sessions, /process-answer, /onepager, /doctor-response" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#8b5cf6;fontSize=14;fontStyle=1;fontColor=#0f2347;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="720" y="205" width="330" height="86" as="geometry"/>
        </mxCell>
        <mxCell id="lambda" value="AWS Lambda Python 3.12&#xa;handler.py, sessions.py, guide.py, onepager.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fb923c;fontSize=14;fontStyle=1;fontColor=#0f2347;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="720" y="320" width="330" height="92" as="geometry"/>
        </mxCell>
        <mxCell id="langgraph" value="LangGraph StateGraph&#xa;input → safety → RAG → LLM extraction&#xa;Pydantic/source_quote validator&#xa;검증 실패 시 bounded retry loop&#xa;Hybrid IR → artifact 저장 → response&#xa;rule-based extraction 대체 없음&#xa;최소 active_path와 node event trace" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontSize=14;fontStyle=1;fontColor=#0f2347;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="720" y="445" width="330" height="246" as="geometry"/>
        </mxCell>
        <mxCell id="langchain" value="LangChain Runnable Node&#xa;ChatPromptTemplate → Bedrock Runnable&#xa;JsonOutputParser → Pydantic schema" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#22c55e;fontSize=14;fontStyle=1;fontColor=#0f2347;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="720" y="725" width="330" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="laneAws" value="4. AWS AI / 데이터 / 보안" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=18;fontStyle=1;fontColor=#0f2347;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="1140" y="130" width="410" height="790" as="geometry"/>
        </mxCell>
        <mxCell id="transcribe" value="Amazon Transcribe Streaming&#xa;한국어 실시간 전사&#xa;음성 원본 S3 저장 없음" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#93c5fd;fontSize=14;fontStyle=1;fontColor=#0f2347;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1180" y="205" width="320" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="bedrock" value="Amazon Bedrock&#xa;Nova Pro: extraction / onepaper review&#xa;Nova Lite: patient guide rewriting" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff1f2;strokeColor=#fb7185;fontSize=14;fontStyle=1;fontColor=#0f2347;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1180" y="330" width="320" height="104" as="geometry"/>
        </mxCell>
        <mxCell id="titan" value="Amazon Titan Embeddings&#xa;Hybrid IR vector similarity&#xa;BM25 + vector + label bridge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#8b5cf6;fontSize=14;fontStyle=1;fontColor=#0f2347;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1180" y="465" width="320" height="94" as="geometry"/>
        </mxCell>
        <mxCell id="ddb" value="DynamoDB&#xa;MunjinSessions&#xa;대기열, 상태, 마스킹 표시명&#xa;S3 artifact key pointer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#22c55e;fontSize=14;fontStyle=1;fontColor=#0f2347;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1180" y="590" width="320" height="116" as="geometry"/>
        </mxCell>
        <mxCell id="s3" value="S3 Artifact Bucket&#xa;answers / onepaper / guide redacted JSON&#xa;llm_trace 최소 설명 trace&#xa;Lifecycle, KMS/SSE, Macie 감사 대상" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#22c55e;fontSize=14;fontStyle=1;fontColor=#0f2347;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="1180" y="735" width="320" height="128" as="geometry"/>
        </mxCell>
        <mxCell id="principles" value="운영 원칙: 음성 원본 저장 금지 · DynamoDB는 최소 상태만 · S3는 가명처리 artifact와 최소 trace · LLM 임의 점수 금지 · 의료 판단은 의료진이 수행" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#93c5fd;fontSize=14;fontStyle=1;fontColor=#0f2347;align=left;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="70" y="790" width="1030" height="82" as="geometry"/>
        </mxCell>
